# Copy to .env and fill in. .env is gitignored -- never commit real keys.

# Claude / Anthropic (used by agents/spintax_humanizer.py)
ANTHROPIC_API_KEY=sk-ant-...

# Instantly.ai API v2 (https://developer.instantly.ai)
INSTANTLY_API_KEY=
INSTANTLY_BASE_URL=https://api.instantly.ai/api/v2

# GoHighLevel (GHL) -- reply -> pipeline sync
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
# Stage IDs for the 7-stage pipeline: New Lead -> Signal Confirmed -> DM Sent ->
# Loom Sent -> Call Booked -> Proposal Sent -> Closed
GHL_STAGE_NEW_LEAD=
GHL_STAGE_SIGNAL_CONFIRMED=
GHL_STAGE_DM_SENT=
GHL_STAGE_LOOM_SENT=
GHL_STAGE_CALL_BOOKED=
GHL_STAGE_PROPOSAL_SENT=
GHL_STAGE_CLOSED=

# HeyGen -- personalized video on positive reply
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Webhook server (scripts/webhook_server.py)
WEBHOOK_SERVER_PORT=8787
# Shared secret Instantly sends back so we can verify inbound webhooks are real
INSTANTLY_WEBHOOK_SECRET=

# Dashboard poller (dashboard/server.py)
DASHBOARD_PORT=8080
DASHBOARD_POLL_INTERVAL_SECONDS=300
